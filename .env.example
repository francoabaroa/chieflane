# Shell internal API key (generate a random string)
SHELL_INTERNAL_API_KEY=your-secret-key-here

# Optional operator auth for the shell UI
SHELL_APP_PASSWORD=
SHELL_APP_SESSION_SECRET=

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# Shell API URL (for OpenClaw plugin to call back)
SHELL_API_URL=http://localhost:3000

# Optional web push (VAPID)
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:you@example.com

# Database path
DATABASE_PATH=./data/chieflane.db
